# Frontend (Vite) — copy to .env.local and fill in.
# All vars exposed to client must be prefixed with VITE_.

# Base URL of the S-121 backend API (no trailing slash).
# Examples:
#   VITE_API_BASE=http://localhost:8080
#   VITE_API_BASE=https://s121-backend-339962740894.asia-southeast1.run.app
VITE_API_BASE=

# Display: mvt (vector tiles + BFF session token) or geojson (legacy).
VITE_DISPLAY_MODE=mvt
