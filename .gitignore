# =============================================================================
# SEA-BANDL — .gitignore
# Diperbarui: 2026-06-05
# Repo: WebGIS Batas Maritim Indonesia (S-121 / IHO)
# =============================================================================


# =============================================================================
# [1] OS FILES
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/


# =============================================================================
# [2] EDITOR & IDE
# =============================================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# =============================================================================
# [3] DEPENDENCIES (Node & Python)
# =============================================================================
# Node — root dan backend masing-masing punya node_modules
node_modules/
backend/node_modules/

# Python virtual environment & cache
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python


# =============================================================================
# [4] BUILD OUTPUTS
# =============================================================================
dist/
dist-ssr/
build/
*.tsbuildinfo


# =============================================================================
# [5] LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
firebase-debug.log
backend/firebase-debug.log


# =============================================================================
# [6] CACHE & LOCAL TOOL OUTPUT
# =============================================================================
# Firebase deploy cache
.firebase/

# Graphify analysis output (tool lokal, bukan bagian proyek)
graphify-out/

# Docker simulation folder (kosong, tidak relevan)
backend/._docker_sim/


# =============================================================================
# [7] ENVIRONMENT & SECRETS
# =============================================================================
# Semua file .env di-ignore; hanya template *.example yang di-track
.env
.env.*
!.env.example
!.env.production.example
!backend/.env.example
*.local

# File kredensial backend (JANGAN PERNAH di-push)
backend/.env
backend/token.txt
backend/db_pass.txt


# =============================================================================
# [8] BINARY LOKAL & EXECUTABLE
# =============================================================================
# Cloud SQL Proxy binary (unduh langsung dari Google, jangan di-push)
cloud-sql-proxy.exe
*.exe
*.dll


# =============================================================================
# [9] ARCHIVED / SUPERSEDED DB SCHEMA
# =============================================================================
# Skema lama yang sudah digantikan real_db_schema/
old_db_schema/


# =============================================================================
# [10] DATA ARSIP / STAGING
# =============================================================================
# Seluruh folder /data sudah diarsipkan — data terbaru ada di real_db_schema/
data/


# =============================================================================
# [11] SCRIPT UTILITAS AD-HOC DI ROOT
# =============================================================================
# Script satu kali pakai yang tidak terstruktur di root — tidak relevan untuk
# kolaborasi atau deployment
analyze_geojson.py
update_sidebar_theme.py
fix_svg.cjs
test_api.js


# =============================================================================
# [12] DOKUMENTASI LOKAL & FILE SAMPAH
# =============================================================================

# --- File .md di root (kecuali dokumentasi resmi) ---
# Pola: ignore semua .md di root, whitelist yang resmi
/*.md
!/README.md
!/CHANGELOG.md

# --- Catatan pribadi & handoff (per file) ---
handsoff.md
real_db_schema/handsoff.md

# --- Catatan presentasi & proposal (bukan bagian proyek teknis) ---
SPEAKER_NOTES.md
/Lembar Proposal*.txt

# --- Draft Tugas Akhir (dokumen privat/lokal) ---
docs/Laporan_TA/

# --- Catatan diskusi AI sementara (bukan dokumentasi resmi) ---
docs/temp_diskusiAI.md

# --- Gambar/aset lokal dokumentasi ---
docs/img/

# --- File ERD SVG (generated/lokal) ---
docs/svg_erd.md

# --- Folder artifacts AI/editor lokal ---
artifacts/

extract_shp.py/

# =============================================================================
# [13] BACKEND — FILE MVT SEMENTARA
# =============================================================================
backend/scripts/*.mvt

# Ignore real_db_schema
real_db_schema/

# Ignore docs and images
*.pdf
*.txt
*.png
*.jpg
*.jpeg
*.gif
*.svg
!public/vite.svg
!src/assets/react.svg

*.webp

*.geojson

docs/
public/docs/

*.py
scripts/
