# ─── Database (Cloud SQL PostgreSQL + PostGIS) ──────────────────────────────
# Local dev (cloud-sql-proxy on TCP):
DB_USER=postgres
DB_PASSWORD=__REDACTED__SET_VIA_SECRET_MANAGER__
DB_NAME=postgres
DB_HOST=127.0.0.1
DB_PORT=35432

# Cloud Run + Cloud SQL — pilih SATU cara (deploy.bat memakai DB_HOST):
# DB_HOST=/cloudsql/your-project:asia-southeast1:your-instance
# DB_PORT=5432
# INSTANCE_UNIX_SOCKET=/cloudsql/your-project:asia-southeast1:your-instance

# Optional pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── CORS allowlist (comma-separated, no trailing slash) ────────────────────
# Empty/unset = allow all (dev only). In production, set explicit origins.
# Example:
#   CORS_ORIGINS=https://your-app.web.app,https://your-app.firebaseapp.com
CORS_ORIGINS=

# ─── Rate limiting ──────────────────────────────────────────────────────────
# Display/MVT APIs: no rate limit by default (zoom = hundreds of tile requests).
# ENABLE_API_RATE_LIMIT=false
# Form permintaan data only:
REQUEST_SUBMIT_MAX=5
REQUEST_SUBMIT_WINDOW_MS=3600000

# ─── Display channel (public WebGIS) ────────────────────────────────────────
# Collection endpoints require ?bbox= when true (recommended for production).
REQUIRE_BBOX=true
# Default simplify (degrees) when client omits ?simplify= (0 = full resolution, larger payloads)
DISPLAY_SIMPLIFY_TOLERANCE=0.0005
# Expose /api/sources, /api/curves, etc. (keep false on public Cloud Run).
ENABLE_METADATA_API=false
DISPLAY_DETAIL_MAX_SOURCES=12

# MVT + BFF display token (recommended for production WebGIS)
# DISPLAY_MODE=mvt
# DISPLAY_REQUIRE_TOKEN=true
# DISPLAY_TOKEN_SECRET=generate-long-random-secret
# DISPLAY_TOKEN_TTL_SECONDS=3600
# DISPLAY_MAX_BBOX_AREA_DEG2=900

# Geoprocessing (/api/geo/*) — stricter bbox than collection harvest
# GEO_MAX_BBOX_AREA_DEG2=25
# GEO_MAX_FEATURES=500
# GEO_MAX_OUTPUT_FEATURES=100
# GEO_MAX_BUFFER_KM=500
# GEO_MAX_INTERSECT_FEATURES=75
# GEO_MAX_INTERSECT_PAIRS=2500

# MVT tile cache (in-memory LRU on Cloud Run instance)
# TILE_CACHE_MAX_ENTRIES=8000
# TILE_CACHE_TTL_SECONDS=3600
# TILE_CACHE_HTTP_MAX_AGE=3600

# Data request form (Phase 3) — set folder writable on VM; Cloud Run needs GCS later
# REQUEST_UPLOAD_DIR=/var/data/s121-request-uploads

# Operator API (header X-Admin-Key) — generate strong random value in production
# DATA_REQUEST_ADMIN_KEY=
# Optional: POST JSON when a new request is submitted (Slack/Teams/custom)
# DATA_REQUEST_NOTIFY_WEBHOOK_URL=
